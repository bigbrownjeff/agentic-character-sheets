node_modules/
.DS_Store

# Generated card images — PNGs are build artifacts; SVGs are tracked
render/cards/*.png

# OS cruft
Thumbs.db
*.swp
*.swo

# scratch preview screenshots
.preview/

# downstream / Instagram card export — kept local, out of the repo
render/
local/

# Card/cover/beat/video/audio media lives in Cloudflare R2 (durable, cheap,
# zero-egress, handles video + audio) — NOT git. We don't grow binary media in
# history. The site loads from the R2 public URL with a Canvas fallback; sync
# with `npm run media:pull` / `media:push`. See site/cards/README.md.
site/cards/**/*.png
site/cards/**/*.jpg
site/cards/**/*.jpeg
site/cards/**/*.webp
site/cards/**/*.gif
site/cards/**/*.mp4
site/cards/**/*.webm
site/cards/**/*.mov
site/cards/**/*.mp3
site/cards/**/*.m4a
site/cards/**/*.wav

# wrangler local state / cache (created by the deploy CLI)
.wrangler/

# session working-notes — local knowledge base, not for this public repo
.claude/handoffs/

# business / monetization strategy — kept local, out of the public repo
business/

# git worktrees created by background agents
.claude/worktrees/
